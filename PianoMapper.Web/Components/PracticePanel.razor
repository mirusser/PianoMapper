<section class="practice-panel" aria-label="Practice controls">
    <div class="controls">
        <button type="button" @onclick="Start" disabled="@(!CanStart)">
            Start / retry practice (T)
        </button>
        <button type="button" @onclick="Abort" disabled="@(!IsActive)">
            Abort practice (C)
        </button>
    </div>
    <p role="status">
        @if (State == PracticeSessionState.CountingIn)
        {
            <span>Count-in @CountInTicksDue of @TotalCountInTicks</span>
        }
        else
        {
            <span>Practice: @State</span>
        }
    </p>
    @if (Result is not null)
    {
        <p>Accuracy: @Result.Summary.AccuracyPercent.ToString("F1", CultureInfo.InvariantCulture)%</p>
        <ul>
            @foreach (var (verdict, count) in Result.Summary.Counts.Where(item => item.Value > 0))
            {
                <li>@GetVerdictLabel(verdict): @count</li>
            }
        </ul>
    }
    <details class="learning-disclosure">
        <summary>How practice feedback works</summary>
        <p>
            The count-in gives you one measure of beats before playing starts. Accuracy is the percentage of expected
            notes graded correct.
        </p>
        <dl class="music-term-grid practice-term-grid">
            <div>
                <dt>Correct</dt>
                <dd>You played the expected pitch close enough to the score's start time and duration.</dd>
            </div>
            <div>
                <dt>Wrong pitch</dt>
                <dd>You played a different piano key near the expected time.</dd>
            </div>
            <div>
                <dt>Early / late</dt>
                <dd>You started the right pitch before or after its expected beat.</dd>
            </div>
            <div>
                <dt>Too short / too long</dt>
                <dd>You released the right pitch sooner or held it longer than its written note value.</dd>
            </div>
            <div>
                <dt>Missed / extra</dt>
                <dd>You skipped an expected note or played one that the score did not contain.</dd>
            </div>
        </dl>
    </details>
</section>

@code {
    private static string GetVerdictLabel(Verdict verdict) => verdict switch
    {
        Verdict.WrongPitch => "Wrong pitch",
        Verdict.TooShort => "Too short",
        Verdict.TooLong => "Too long",
        _ => verdict.ToString(),
    };

    [Parameter]
    public PracticeSessionState State { get; set; }

    [Parameter]
    public GradingResult? Result { get; set; }

    [Parameter]
    public int CountInTicksDue { get; set; }

    [Parameter]
    public int TotalCountInTicks { get; set; }

    [Parameter]
    public bool CanStart { get; set; }

    [Parameter]
    public bool IsActive { get; set; }

    [Parameter]
    public EventCallback Start { get; set; }

    [Parameter]
    public EventCallback Abort { get; set; }
}
