@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="visualization-stack">
    <section class="visualization-panel" aria-labelledby="piano-view-heading">
        <div class="visualization-panel-header">
            <div>
                <p class="panel-kicker">Notes</p>
                <h2 id="piano-view-heading">@SceneTitle</h2>
            </div>
            <span class="panel-context">@SceneContext</span>
        </div>
        <p class="panel-description">@SceneDescription</p>
        <div class="legend" aria-label="Note color legend">
            <span><span class="legend-mark legend-mark-active"></span>Pressed by you</span>
            <span><span class="legend-mark legend-mark-finished"></span>Released or expected</span>
        </div>
        <canvas @ref="canvas" class="piano-canvas" role="img" aria-label="@SceneLabel">
            Piano visualization.
        </canvas>
    </section>

    <div class="analysis-controls" role="group" aria-label="Audio visualizers">
        <span>Audio visualizers</span>
        <button class="button-quiet"
                type="button"
                aria-controls="waveform-analysis-panel"
                aria-pressed="@(isWaveformVisible ? "true" : "false")"
                @onclick="ToggleWaveform">
            @(isWaveformVisible ? "Hide waveform" : "Show waveform")
        </button>
        <button class="button-quiet"
                type="button"
                aria-controls="spectrum-analysis-panel"
                aria-pressed="@(isFrequencySpectrumVisible ? "true" : "false")"
                @onclick="ToggleFrequencySpectrum">
            @(isFrequencySpectrumVisible ? "Hide frequency spectrum" : "Show frequency spectrum")
        </button>
    </div>

    <div class="analysis-grid @(isWaveformVisible != isFrequencySpectrumVisible ? "analysis-grid-single" : null)">
        <figure id="waveform-analysis-panel" class="analysis-panel" hidden="@(!isWaveformVisible)">
            <div class="visualization-panel-header">
                <div>
                    <p class="panel-kicker">Sound shape</p>
                    <h2>Waveform</h2>
                </div>
                <span class="legend-line legend-line-waveform">Signal</span>
            </div>
            <p class="panel-description">
                Time runs left to right across the latest audio window. Distance from the center line shows signal
                amplitude, not pitch.
            </p>
            <canvas @ref="waveformCanvas"
                    class="analysis-canvas"
                    role="img"
                    aria-label="Live audio waveform: time runs from left to right and distance from the center shows signal strength.">
                Live audio waveform.
            </canvas>
            <div class="axis-legend" aria-hidden="true">
                <span>Earlier</span>
                <span>Time →</span>
                <span>Now</span>
            </div>
        </figure>

        <figure id="spectrum-analysis-panel" class="analysis-panel" hidden="@(!isFrequencySpectrumVisible)">
            <div class="visualization-panel-header">
                <div>
                    <p class="panel-kicker">Sound ingredients</p>
                    <h2>Frequency spectrum</h2>
                </div>
                <span class="legend-line legend-line-spectrum">Relative strength</span>
            </div>
            <p class="panel-description">
                Bars run from lower to higher frequencies. The fundamental sets the note's pitch; the pattern of
                higher overtones shapes its piano-like tone.
            </p>
            <canvas @ref="spectrumCanvas"
                    class="analysis-canvas"
                    role="img"
                    aria-label="Live frequency spectrum: lower-pitched frequencies are on the left, higher-pitched frequencies are on the right, and bar height shows relative strength.">
                Live frequency spectrum.
            </canvas>
            <div class="axis-legend" aria-hidden="true">
                <span>Low pitch</span>
                <span>Frequency →</span>
                <span>High pitch</span>
            </div>
        </figure>
    </div>

    <details class="learning-disclosure visualization-help">
        <summary>Read the notation and sound views</summary>
        <p>
            Use the grand staff to read written pitch and duration. Switch to the piano roll to compare pitch and
            time directly. The waveform and spectrum show two views of the audio behind the note.
        </p>
        <dl class="music-term-grid">
            <div>
                <dt>Grand staff</dt>
                <dd>
                    The treble and bass staves meet around middle C. Notes rise through their lines and spaces as pitch
                    rises.
                </dd>
            </div>
            <div>
                <dt>Clef</dt>
                <dd>
                    A clef assigns note names to staff positions. The treble clef curls around G on the second line;
                    the bass-clef dots surround F on the fourth line.
                </dd>
            </div>
            <div>
                <dt>Ledger line</dt>
                <dd>
                    A short line extends the staff for a note outside its five lines. Count ledger lines and spaces the
                    same way you count positions inside the staff.
                </dd>
            </div>
            <div>
                <dt>Live and written notes</dt>
                <dd>
                    Vertical position gives the pitch. While you hold a key, a trail grows to show elapsed time. On
                    release, PianoMapper chooses the nearest whole, half, quarter, eighth, or sixteenth-note symbol.
                </dd>
            </div>
            <div>
                <dt>Pitch name, such as C♯4</dt>
                <dd>
                    C♯4 means C sharp in octave 4. A sharp raises a pitch by one piano key, a flat lowers it by one,
                    and the octave number changes when the letter name reaches C.
                </dd>
            </div>
            <div>
                <dt>Barline and measure</dt>
                <dd>
                    Vertical barlines divide the score into measures. Each measure contains the number of beats set by
                    the time signature's top number.
                </dd>
            </div>
            <div>
                <dt>Playback cursor</dt>
                <dd>The vertical cursor crosses each beat at its scheduled time during score playback or practice.</dd>
            </div>
            <div>
                <dt>Piano roll</dt>
                <dd>
                    Each bar maps one note across two axes: left to right shows time, low to high shows pitch, and bar
                    length shows how long the note sounded.
                </dd>
            </div>
        </dl>
        <p class="learning-links">
            For illustrated notation lessons, see
            <a href="https://www.musictheory.net/lessons/10" target="_blank" rel="noopener noreferrer">The Staff, Clefs, and Ledger Lines</a>
            and
            <a href="https://www.musictheory.net/lessons/11" target="_blank" rel="noopener noreferrer">Note Duration</a>
            on MusicTheory.net.
        </p>
    </details>
</div>

@code {
    private static readonly CanvasAnalysisLayout AnalysisLayout = new(SpectrumLayout.VisibleBinCount);

    private ElementReference canvas;
    private ElementReference waveformCanvas;
    private ElementReference spectrumCanvas;
    private IJSObjectReference? module;
    private bool isWaveformVisible;
    private bool isFrequencySpectrumVisible;

    [Parameter, EditorRequired]
    public IPianoCanvasScene Scene { get; set; } = new GrandStaffScene([], [], []);

    [Parameter]
    public int SelectedOctave { get; set; } = 4;

    [Parameter]
    public bool IsScoreView { get; set; }

    [Parameter]
    public ScoreCursorPlaybackState? ScoreCursor { get; set; }

    private ScoreCursorPlaybackState? lastPushedScoreCursor;

    private string SceneTitle => Scene.Kind == PianoCanvasSceneKind.PianoRoll
        ? "Piano roll"
        : "Grand staff";

    private string SceneContext => Scene.Kind == PianoCanvasSceneKind.PianoRoll
        ? "Last 8 seconds"
        : IsScoreView
            ? "Imported score"
            : $"Keyboard C{SelectedOctave}–C{SelectedOctave + 1}";

    private string SceneDescription => Scene.Kind == PianoCanvasSceneKind.PianoRoll
        ? "Time moves from left to right; higher notes appear higher in the panel."
        : IsScoreView
            ? "The upper five lines are the treble staff and the lower five are the bass staff."
            : "The view follows the selected keyboard octave while preserving each note's real position on the staff.";

    private string SceneLabel => Scene.Kind == PianoCanvasSceneKind.PianoRoll
        ? "Scrolling piano roll"
        : IsScoreView
            ? "Grand staff for the imported score"
            : $"Live grand staff focused on keyboard octave {SelectedOctave}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/canvas.js");
            await module.InvokeVoidAsync(
                "initialize",
                canvas,
                waveformCanvas,
                spectrumCanvas,
                AnalysisLayout);
        }

        // Update the JS-side cursor state before render() so its draw() call already reflects
        // the current cursor, instead of drawing one stale frame first.
        if (ScoreCursor != lastPushedScoreCursor)
        {
            lastPushedScoreCursor = ScoreCursor;
            if (ScoreCursor is null)
            {
                await module!.InvokeVoidAsync("stopScoreCursor", canvas);
            }
            else
            {
                await module!.InvokeVoidAsync("startScoreCursor", canvas, ScoreCursor);
            }
        }

        await module!.InvokeVoidAsync(
            "render",
            canvas,
            Scene,
            isWaveformVisible,
            isFrequencySpectrumVisible);
    }

    private void ToggleWaveform() => isWaveformVisible = !isWaveformVisible;

    private void ToggleFrequencySpectrum() => isFrequencySpectrumVisible = !isFrequencySpectrumVisible;

    public async ValueTask DisposeAsync()
    {
        if (module is null)
        {
            return;
        }

        await module.InvokeVoidAsync("dispose", canvas);
        await module.DisposeAsync();
    }
}
