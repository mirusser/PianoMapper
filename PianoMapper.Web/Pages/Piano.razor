@page "/"
@implements IAsyncDisposable
@inject WebAudioSession AudioSession
@inject BrowserMetronome Metronome
@inject BrowserScorePlayback ScorePlaybackSession
@inject IJSRuntime JS

<PageTitle>PianoMapper</PageTitle>

<main>
    <header class="page-header">
        <div>
            <p class="eyebrow">Play · see · understand</p>
            <h1>PianoMapper</h1>
            <p class="page-intro">Use your computer keyboard as a small piano and see each note as you play.</p>
        </div>
        <p class="status-chip" role="status">@audioStatus</p>
    </header>
    <section @ref="playSurface" class="play-surface" tabindex="0" aria-label="Piano play surface">
        <div class="control-dashboard">
            <section class="control-card" aria-labelledby="audio-controls-heading">
                <div class="control-card-heading">
                    <h2 id="audio-controls-heading">Audio</h2>
                </div>
                <div class="audio-controls">
                    <div class="audio-primary-actions">
                        <button class="button-primary" type="button" @onclick="EnableAudioAsync" disabled="@AudioSession.IsInitialized">
                            Enable audio
                        </button>
                        <div class="sound-source-picker" role="group" aria-label="Sound source">
                            <button class="@GetSoundSourceClass(BrowserSoundSource.Synth)"
                                    type="button"
                                    aria-pressed="@(soundSource == BrowserSoundSource.Synth)"
                                    disabled="@(!AudioSession.IsInitialized || isSoundSourceChanging)"
                                    @onclick="() => SelectSoundSourceAsync(BrowserSoundSource.Synth)">
                                Synth
                            </button>
                            <button class="@GetSoundSourceClass(BrowserSoundSource.Piano)"
                                    type="button"
                                    aria-pressed="@(soundSource == BrowserSoundSource.Piano)"
                                    disabled="@(!AudioSession.IsInitialized || isSoundSourceChanging)"
                                    @onclick="() => SelectSoundSourceAsync(BrowserSoundSource.Piano)">
                                Piano
                            </button>
                        </div>
                    </div>
                    <div class="controls audio-secondary-actions">
                        <button type="button" @onclick="PlayTestNoteAsync" disabled="@(!AudioSession.IsInitialized || testNoteIsActive)">
                            Play test note
                        </button>
                        <button type="button" @onclick="StopTestNoteAsync" disabled="@(!testNoteIsActive)">Stop test note</button>
                        <button class="button-quiet" type="button" @onclick="ShowTimingAsync" disabled="@(!AudioSession.IsInitialized)">
                            Show input latency
                        </button>
                    </div>
                </div>
            </section>

            <section class="control-card" aria-labelledby="timing-controls-heading">
                <div class="control-card-heading">
                    <h2 id="timing-controls-heading">Timing</h2>
                    <span>@TimingLabel</span>
                </div>
                <div class="timing-controls">
                    <label class="timing-field">
                        <span>Beats per measure</span>
                        <input type="number"
                               min="@MinimumMeterNumerator"
                               max="@MaximumMeterNumerator"
                               step="1"
                               value="@displayTimeSignature.Numerator"
                               @onchange="SelectMeterNumeratorAsync" />
                    </label>
                    <label class="timing-field">
                        <span>One beat is a</span>
                        <select value="@displayTimeSignature.BeatNoteValue.Denominator"
                                @onchange="SelectBeatNoteAsync">
                            <option value="1">Whole note (1)</option>
                            <option value="2">Half note (2)</option>
                            <option value="4">Quarter note (4)</option>
                            <option value="8">Eighth note (8)</option>
                            <option value="16">Sixteenth note (16)</option>
                        </select>
                    </label>
                    <label class="timing-field">
                        <span>Tempo (BPM)</span>
                        <input type="number"
                               min="@MinimumTempoBeatsPerMinute"
                               max="@MaximumTempoBeatsPerMinute"
                               step="1"
                               value="@TempoBeatsPerMinuteText"
                               @onchange="SelectTempoAsync" />
                    </label>
                    <label class="timing-field">
                        <span>On-time tolerance</span>
                        <select value="@OnTimeToleranceMilliseconds"
                                @onchange="SelectOnTimeToleranceAsync">
                            <option value="@StrictToleranceMilliseconds">Strict (30 ms)</option>
                            <option value="@NormalToleranceMilliseconds">Normal (60 ms)</option>
                            <option value="@RelaxedToleranceMilliseconds">Relaxed (100 ms)</option>
                        </select>
                    </label>
                </div>
                <p class="control-note">
                    Timing changes stop score or practice playback. A running metronome restarts on the new beat grid.
                </p>
                <details class="learning-disclosure">
                    <summary>Understand the timing controls</summary>
                    <dl class="music-term-grid">
                        <div>
                            <dt>Beat</dt>
                            <dd>
                                The pulse you tap or count. The “One beat is a” control chooses the note value assigned
                                to each metronome click in PianoMapper.
                            </dd>
                        </div>
                        <div>
                            <dt>Measure (or bar)</dt>
                            <dd>
                                One group of beats between two barlines. With three beats per measure, the count returns
                                to beat one after every third beat.
                            </dd>
                        </div>
                        <div>
                            <dt>Time signature</dt>
                            <dd>
                                PianoMapper combines the first two controls as the written pair. 3/4 means three beats
                                per measure and a quarter note receives one beat.
                            </dd>
                        </div>
                        <div>
                            <dt>Note value</dt>
                            <dd>
                                Whole, half, quarter, eighth, and sixteenth notes describe relative duration. A half
                                note lasts twice as long as a quarter note; an eighth lasts half as long.
                            </dd>
                        </div>
                        <div>
                            <dt>Tempo (BPM)</dt>
                            <dd>
                                Beats per minute converts the selected beat into clock time. At 120 BPM, each beat lasts
                                half a second.
                            </dd>
                        </div>
                        <div>
                            <dt>On-time tolerance</dt>
                            <dd>
                                With Normal selected, PianoMapper marks onsets within 60 ms of their expected time as on
                                time. Larger deviations are early or late.
                            </dd>
                        </div>
                    </dl>
                    <p class="learning-links">
                        For illustrated walkthroughs, see
                        <a href="https://www.musictheory.net/lessons/11" target="_blank" rel="noopener noreferrer">Note Duration</a>
                        and
                        <a href="https://www.musictheory.net/lessons/12" target="_blank" rel="noopener noreferrer">Measures and Time Signature</a>
                        on MusicTheory.net.
                    </p>
                </details>
            </section>

            <section class="score-card control-card-wide" aria-label="MusicXML score">
                <ScoreFilePicker ScoreLoaded="HandleScoreLoadedAsync" />
                @if (loadedScore is not null)
                {
                    <p class="score-title">@loadedScore.Title — @loadedScore.Measures.Count measure(s)</p>
                    <div class="controls" aria-label="Score navigation">
                        <button class="button-primary"
                                type="button"
                                @onclick="StartScorePlaybackAsync"
                                disabled="@(!AudioSession.IsInitialized)">
                            Play / restart <kbd>P</kbd>
                        </button>
                        <button type="button" @onclick="ShowPreviousMeasures" disabled="@(firstVisibleMeasure == 0)">
                            Previous <kbd>[</kbd>
                        </button>
                        <span class="measure-window">
                            Measures @(firstVisibleMeasure + 1)–@Math.Min(
                                firstVisibleMeasure + GrandStaffLayout.VisibleMeasureCount,
                                loadedScore.Measures.Count)
                        </span>
                        <button type="button"
                                @onclick="ShowNextMeasures"
                                disabled="@(firstVisibleMeasure >= loadedScore.Measures.Count - 1)">
                            Next <kbd>]</kbd>
                        </button>
                    </div>
                    <PracticePanel State="@practiceCoordinator.State"
                                   Result="@practiceCoordinator.Result"
                                   CountInTicksDue="@practiceCoordinator.CountInTicksDue"
                                   TotalCountInTicks="@loadedScore.TimeSignature.Numerator"
                                   CanStart="@AudioSession.IsInitialized"
                                   IsActive="@practiceCoordinator.IsActive"
                                   Start="StartPracticeAsync"
                                   Abort="AbortPracticeFromControlAsync" />
                }
            </section>

            <section class="control-card control-card-wide" aria-labelledby="play-controls-heading">
                <div class="control-card-heading">
                    <h2 id="play-controls-heading">Play &amp; keyboard tools</h2>
                    <span>C@(keyboardState.CurrentOctave)–C@(keyboardState.CurrentOctave + 1)</span>
                </div>
                <div class="control-card-groups">
                    <div class="control-group" role="group" aria-labelledby="play-tools-heading">
                        <span class="control-group-label" id="play-tools-heading">Play tools</span>
                        <div class="controls">
                            <button type="button" @onclick="ClearNotesAsync" disabled="@(!AudioSession.IsInitialized)">
                                Clear notes <kbd>C</kbd>
                            </button>
                            <button type="button" @onclick="PlayRandomMeasureAsync" disabled="@(!AudioSession.IsInitialized)">
                                Random measure <kbd>M</kbd>
                            </button>
                            <button class="button-quiet" type="button" @onclick="ToggleViewAsync">
                                Show @(showPianoRoll ? "staff" : "piano roll") <kbd>V</kbd>
                            </button>
                        </div>
                    </div>

                    <div class="control-group" role="group" aria-labelledby="keyboard-range-heading">
                        <span class="control-group-label" id="keyboard-range-heading">Keyboard range</span>
                        <div class="controls octave-controls">
                            <button type="button"
                                    @onclick="OctaveDownAsync"
                                    disabled="@(keyboardState.CurrentOctave == 1)"
                                    aria-label="Select the previous octave">
                                Down <kbd>Z</kbd>
                            </button>
                            <label class="octave-picker">
                                Octave
                                <select value="@keyboardState.CurrentOctave" @onchange="SelectOctaveAsync">
                                    @for (int octave = 1; octave <= 8; octave++)
                                    {
                                        <option value="@octave">@octave</option>
                                    }
                                </select>
                            </label>
                            <button type="button"
                                    @onclick="OctaveUpAsync"
                                    disabled="@(keyboardState.CurrentOctave == 8)"
                                    aria-label="Select the next octave">
                                Up <kbd>X</kbd>
                            </button>
                        </div>
                    </div>
                </div>
                <p class="control-note">The staff follows this range so high and low octaves stay visible.</p>
            </section>
        </div>

        <MetronomeControls IsRunning="@Metronome.IsRunning"
                            CanToggle="@AudioSession.IsInitialized"
                            Feedback="@tempoFeedbackTracker"
                            Toggle="ToggleMetronomeAsync" />

        <div class="session-summary" aria-label="Current piano settings">
            <span>Meter <strong>@displayTimeSignature.Numerator/@displayTimeSignature.BeatNoteValue.Denominator</strong></span>
            <span>Tempo <strong>@TempoBeatsPerMinuteText BPM</strong></span>
            <span>Play keys <strong>A W S E D F R J U K I L ;</strong></span>
        </div>
        <PianoCanvas Scene="@canvasScene"
                     SelectedOctave="@keyboardState.CurrentOctave"
                     IsScoreView="@(loadedScore is not null && !showPianoRoll)"
                     ScoreCursor="@scoreCursorState" />
    </section>
</main>

@code {
    private const string TestNoteId = "test-note";
    private const int MinimumMeterNumerator = 1;
    private const int MaximumMeterNumerator = 12;
    private const int MinimumTempoBeatsPerMinute = 30;
    private const int MaximumTempoBeatsPerMinute = 300;
    private const int StrictToleranceMilliseconds = 30;
    private const int NormalToleranceMilliseconds = 60;
    private const int RelaxedToleranceMilliseconds = 100;
    private static readonly Pitch TestPitch = new(NoteLetter.A, 0, 4);
    private static readonly TimeSpan BrowserSchedulingLead = TimeSpan.FromMilliseconds(50);
    private static readonly TimeSpan CanvasRefreshInterval = TimeSpan.FromMilliseconds(16);

    // How often RefreshScorePlaybackAsync polls purely to notice that playback has finished.
    // The cursor itself no longer depends on this cadence at all — it is animated client-side
    // (canvas.js) from the Web Audio clock, so this can be coarse.
    private static readonly TimeSpan PlaybackCompletionPollInterval = TimeSpan.FromMilliseconds(250);

    private readonly NoteTimeline noteTimeline = new();
    private readonly TempoFeedbackTracker tempoFeedbackTracker = new();
    private readonly BrowserKeyboardState keyboardState;
    private readonly GrandStaffSceneCache grandStaffSceneCache = new();
    private ElementReference playSurface;
    private AudioClockAnchor? audioClockAnchor;
    private IJSObjectReference? keyboardModule;
    private DotNetObjectReference<Piano>? keyboardReference;
    private IPianoCanvasScene canvasScene = GrandStaffSceneBuilder.Build([], TimeSpan.Zero, selectedOctave: 4);
    private ScoreCursorPlaybackState? scoreCursorState;
    private Score? importedScore;
    private Score? loadedScore;
    private int firstVisibleMeasure;
    private CancellationTokenSource? playbackRefreshCancellation;
    private Task? playbackRefreshTask;
    private BrowserPracticeCoordinator practiceCoordinator = null!;
    private CancellationTokenSource? practiceRefreshCancellation;
    private Task? practiceRefreshTask;
    private CancellationTokenSource? visualizationRefreshCancellation;
    private Task? visualizationRefreshTask;
    private string audioStatus = "Audio is not initialized.";
    private BrowserSoundSource soundSource = BrowserSoundSource.Synth;
    private bool isSoundSourceChanging;
    private bool testNoteIsActive;
    private bool showPianoRoll;
    private TimeSignature displayTimeSignature = new(4, new NoteValue(4));
    private Tempo displayTempo = new(120);
    private TimeSpan onTimeTolerance = TimeSpan.FromMilliseconds(NormalToleranceMilliseconds);

    private string TempoBeatsPerMinuteText =>
        displayTempo.BeatsPerMinute.ToString("F0", CultureInfo.InvariantCulture);

    private string TimingLabel =>
        $"{displayTimeSignature.Numerator}/{displayTimeSignature.BeatNoteValue.Denominator} · " +
        $"{TempoBeatsPerMinuteText} BPM";

    private int OnTimeToleranceMilliseconds => (int)onTimeTolerance.TotalMilliseconds;

    private string AudioReadyStatus => soundSource == BrowserSoundSource.Piano
        ? "Piano samples are ready."
        : "Synth audio is ready.";

    public Piano()
    {
        keyboardState = new BrowserKeyboardState(noteTimeline, initialOctave: 4);
    }

    protected override void OnInitialized()
    {
        practiceCoordinator = new BrowserPracticeCoordinator(AudioSession, noteTimeline);
    }

    private async Task EnableAudioAsync()
    {
        try
        {
            audioClockAnchor = await AudioSession.InitializeAsync();
            await AttachKeyboardAsync();
            audioStatus = AudioReadyStatus;
            EnsureVisualizationRefresh();
        }
        catch (JSException exception)
        {
            audioStatus = $"Audio could not start: {exception.Message} Select Enable audio to retry.";
        }
    }

    private async Task PlayTestNoteAsync()
    {
        await AudioSession.StartNoteAsync(TestNoteId, TestPitch, GetAnchorTime(), shouldMeasureLatency: false);
        testNoteIsActive = true;
        audioStatus = "Test note is playing.";
    }

    private async Task StopTestNoteAsync()
    {
        await AudioSession.StopNoteAsync(TestNoteId, GetAnchorTime());
        testNoteIsActive = false;
        audioStatus = AudioReadyStatus;
    }

    private async Task SelectSoundSourceAsync(BrowserSoundSource selectedSource)
    {
        if (!AudioSession.IsInitialized || selectedSource == soundSource || isSoundSourceChanging)
        {
            return;
        }

        isSoundSourceChanging = true;
        audioStatus = selectedSource == BrowserSoundSource.Piano
            ? "Loading piano samples..."
            : "Switching to synth audio...";
        try
        {
            await AbortPracticeAsync(updateStatus: false);
            await StopScorePlaybackAsync();
            TimeSpan currentTime = await AudioSession.GetCurrentTimeAsync();
            keyboardState.Clear(currentTime);
            await AudioSession.ClearAsync(currentTime);
            testNoteIsActive = false;
            await AudioSession.SetSoundSourceAsync(selectedSource);
            soundSource = selectedSource;
            audioStatus = AudioReadyStatus;
        }
        catch (JSException exception)
        {
            audioStatus = $"Sound could not change: {exception.Message}";
        }
        finally
        {
            isSoundSourceChanging = false;
        }
    }

    private string GetSoundSourceClass(BrowserSoundSource source) =>
        source == soundSource
            ? "sound-source-option sound-source-option-active"
            : "sound-source-option";

    private async Task ClearNotesAsync()
    {
        await ApplyInputCommandAsync(keyboardState.Clear(GetAnchorTime()));
    }

    private async Task ShowTimingAsync()
    {
        var summary = await AudioSession.GetSchedulingLatencyAsync();
        audioStatus = summary.SampleCount == 0
            ? "No keyboard timing samples recorded yet."
            : $"{summary.SampleCount} samples: median {summary.MedianMilliseconds:F1} ms, p95 {summary.P95Milliseconds:F1} ms.";
    }

    private async Task HandleScoreLoadedAsync(Score score)
    {
        await AbortPracticeAsync(updateStatus: false);
        await StopScorePlaybackAsync();
        bool metronomeWasRunning = Metronome.IsRunning;
        if (metronomeWasRunning)
        {
            await StopMetronomeAsync();
        }

        importedScore = score;
        loadedScore = score;
        displayTimeSignature = score.TimeSignature;
        displayTempo = score.Tempo;
        if (metronomeWasRunning)
        {
            await StartMetronomeAsync();
            audioStatus = $"Metronome on at {TimingLabel}.";
        }

        firstVisibleMeasure = 0;
        TimeSpan currentTime = AudioSession.IsInitialized
            ? await AudioSession.GetCurrentTimeAsync()
            : TimeSpan.Zero;
        RefreshCanvasScene(currentTime);
    }

    private async Task StartScorePlaybackAsync()
    {
        if (loadedScore is null || !AudioSession.IsInitialized)
        {
            return;
        }

        await AbortPracticeAsync(updateStatus: false);
        await CancelVisualizationRefreshAsync();
        await CancelPlaybackRefreshAsync();
        await ScorePlaybackSession.StartAsync(loadedScore);
        displayTimeSignature = loadedScore.TimeSignature;
        displayTempo = loadedScore.Tempo;
        // canvasScene already reflects the current static score view (built at load/measure-nav
        // time); starting playback only needs to hand the cursor animation off to JS.
        scoreCursorState = BuildScoreCursorState();
        playbackRefreshCancellation = new CancellationTokenSource();
        playbackRefreshTask = RefreshScorePlaybackAsync(playbackRefreshCancellation.Token);
        audioStatus = $"Playing {loadedScore.Title}.";
    }

    private async Task PlayRandomMeasureAsync()
    {
        if (!AudioSession.IsInitialized)
        {
            return;
        }

        await AbortPracticeAsync(updateStatus: false);
        await StopScorePlaybackAsync();
        var measure = RandomMeasureComposer.Compose(
            [TestPitch],
            displayTimeSignature,
            displayTempo,
            Random.Shared);
        TimeSpan anchor = await AudioSession.GetCurrentTimeAsync() + BrowserSchedulingLead;
        await AudioSession.ScheduleScoreAsync(BrowserRandomMeasureScheduler.CreateEvents(measure, anchor));
        audioStatus = $"Playing a random measure at {TimingLabel}.";
    }

    private async Task StartPracticeAsync()
    {
        if (loadedScore is null || !AudioSession.IsInitialized)
        {
            return;
        }

        if (Metronome.IsRunning)
        {
            await StopMetronomeAsync();
        }

        await StopScorePlaybackAsync();
        await AbortPracticeAsync(updateStatus: false);
        await CancelVisualizationRefreshAsync();
        TimeSpan currentTime = await AudioSession.GetCurrentTimeAsync();
        keyboardState.Clear(currentTime);
        await AudioSession.ClearAsync(currentTime);
        await practiceCoordinator.StartAsync(
            loadedScore,
            new GradingOptions { OnTimeTolerance = onTimeTolerance });
        practiceRefreshCancellation = new CancellationTokenSource();
        practiceRefreshTask = RefreshPracticeAsync(practiceRefreshCancellation.Token);
        audioStatus = "Practice count-in started.";
    }

    private async Task AbortPracticeFromControlAsync()
    {
        if (!AudioSession.IsInitialized)
        {
            return;
        }

        await AbortPracticeAsync(await AudioSession.GetCurrentTimeAsync());
    }

    private async Task StopScorePlaybackAsync()
    {
        await CancelPlaybackRefreshAsync();
        scoreCursorState = null;
        if (AudioSession.IsInitialized)
        {
            await ScorePlaybackSession.StopAsync();
        }

        if (loadedScore is not null)
        {
            RefreshCanvasScene(GetAnchorTime());
        }
    }

    private void ShowPreviousMeasures()
    {
        if (loadedScore is null)
        {
            return;
        }

        firstVisibleMeasure = GrandStaffSceneBuilder.ClampFirstVisibleMeasure(
            loadedScore,
            firstVisibleMeasure - GrandStaffLayout.VisibleMeasureCount);
        UpdateScoreCursorMeasureIfPlaying();
        if (!showPianoRoll)
        {
            RefreshCanvasScene(GetAnchorTime());
        }
    }

    private void ShowNextMeasures()
    {
        if (loadedScore is null)
        {
            return;
        }

        firstVisibleMeasure = GrandStaffSceneBuilder.ClampFirstVisibleMeasure(
            loadedScore,
            firstVisibleMeasure + GrandStaffLayout.VisibleMeasureCount);
        UpdateScoreCursorMeasureIfPlaying();
        if (!showPianoRoll)
        {
            RefreshCanvasScene(GetAnchorTime());
        }
    }

    // Measure navigation during active score playback needs the JS-side cursor to reposition
    // against the new visible window on the next render, without restarting the audio-clock
    // anchor it was given at StartScorePlaybackAsync.
    private void UpdateScoreCursorMeasureIfPlaying()
    {
        if (ScorePlaybackSession.IsActive)
        {
            scoreCursorState = BuildScoreCursorState();
        }
    }

    // The small set of numbers JS needs to animate the score-playback cursor itself, every
    // animation frame, from audioContext.currentTime — see canvas.js's drawScoreCursor(). Null
    // while nothing should be drawn (no active score playback, or the piano-roll view is showing,
    // which never displayed a grand-staff cursor either).
    private ScoreCursorPlaybackState? BuildScoreCursorState()
    {
        if (showPianoRoll || loadedScore is null || ScorePlaybackSession.GetCursorAnchor() is not { } anchor)
        {
            return null;
        }

        var (cursorY0, cursorY1) = GrandStaffSceneBuilder.GetCursorLineYBounds();
        return new ScoreCursorPlaybackState(
            anchor.AnchorSeconds,
            anchor.BeatsPerMinute,
            loadedScore.TimeSignature.Numerator,
            firstVisibleMeasure,
            anchor.CompletionSeconds,
            cursorY0,
            cursorY1);
    }

    private Task OctaveDownAsync() =>
        ApplyInputCommandAsync(keyboardState.ChangeOctave(keyboardState.CurrentOctave - 1, GetAnchorTime()));

    private Task OctaveUpAsync() =>
        ApplyInputCommandAsync(keyboardState.ChangeOctave(keyboardState.CurrentOctave + 1, GetAnchorTime()));

    private Task SelectOctaveAsync(ChangeEventArgs eventArgs)
    {
        int octave = int.Parse((string)eventArgs.Value!, CultureInfo.InvariantCulture);
        return ApplyInputCommandAsync(keyboardState.ChangeOctave(octave, GetAnchorTime()));
    }

    private Task SelectMeterNumeratorAsync(ChangeEventArgs eventArgs)
    {
        int numerator = ParseClampedInteger(
            eventArgs,
            displayTimeSignature.Numerator,
            MinimumMeterNumerator,
            MaximumMeterNumerator);
        return ApplyTimingAsync(
            new TimeSignature(numerator, displayTimeSignature.BeatNoteValue),
            displayTempo);
    }

    private Task SelectBeatNoteAsync(ChangeEventArgs eventArgs)
    {
        int denominator = int.Parse((string)eventArgs.Value!, CultureInfo.InvariantCulture);
        return ApplyTimingAsync(
            new TimeSignature(displayTimeSignature.Numerator, new NoteValue(denominator)),
            displayTempo);
    }

    private Task SelectTempoAsync(ChangeEventArgs eventArgs)
    {
        int beatsPerMinute = ParseClampedInteger(
            eventArgs,
            (int)displayTempo.BeatsPerMinute,
            MinimumTempoBeatsPerMinute,
            MaximumTempoBeatsPerMinute);
        return ApplyTimingAsync(displayTimeSignature, new Tempo(beatsPerMinute));
    }

    private Task SelectOnTimeToleranceAsync(ChangeEventArgs eventArgs)
    {
        int milliseconds = int.Parse((string)eventArgs.Value!, CultureInfo.InvariantCulture);
        onTimeTolerance = TimeSpan.FromMilliseconds(milliseconds);
        tempoFeedbackTracker.Reset();
        audioStatus = $"On-time tolerance set to {milliseconds} ms.";
        return Task.CompletedTask;
    }

    private async Task ToggleMetronomeAsync()
    {
        if (Metronome.IsRunning)
        {
            await StopMetronomeAsync();
            audioStatus = "Metronome off.";
        }
        else
        {
            await StartMetronomeAsync();
            audioStatus = $"Metronome on at {TimingLabel}.";
        }
    }

    private async Task StartMetronomeAsync()
    {
        tempoFeedbackTracker.Reset();
        await Metronome.StartAsync(displayTimeSignature, displayTempo);
    }

    private async Task StopMetronomeAsync()
    {
        await Metronome.StopAsync();
        tempoFeedbackTracker.Reset();
    }

    private async Task ApplyTimingAsync(TimeSignature timeSignature, Tempo tempo)
    {
        bool metronomeWasRunning = Metronome.IsRunning;
        if (metronomeWasRunning)
        {
            await StopMetronomeAsync();
        }

        bool playbackWasActive = ScorePlaybackSession.IsActive || practiceCoordinator.IsActive;
        await AbortPracticeAsync(updateStatus: false);
        await StopScorePlaybackAsync();

        displayTimeSignature = timeSignature;
        displayTempo = tempo;
        if (importedScore is not null)
        {
            loadedScore = ScoreTiming.Apply(importedScore, timeSignature, tempo);
        }

        TimeSpan currentTime = AudioSession.IsInitialized
            ? await AudioSession.GetCurrentTimeAsync()
            : TimeSpan.Zero;
        if (metronomeWasRunning)
        {
            await StartMetronomeAsync();
        }

        RefreshCanvasScene(currentTime);
        audioStatus = metronomeWasRunning
            ? $"Metronome on at {TimingLabel}."
            : playbackWasActive
                ? $"Timing set to {TimingLabel}. Start playback again to use it."
                : $"Timing set to {TimingLabel}.";
    }

    private static int ParseClampedInteger(
        ChangeEventArgs eventArgs,
        int fallback,
        int minimum,
        int maximum)
    {
        bool parsed = int.TryParse(
            eventArgs.Value?.ToString(),
            NumberStyles.Integer,
            CultureInfo.InvariantCulture,
            out int value);
        return Math.Clamp(parsed ? value : fallback, minimum, maximum);
    }

    private async Task ToggleViewAsync()
    {
        TimeSpan currentTime = AudioSession.IsInitialized
            ? await AudioSession.GetCurrentTimeAsync()
            : TimeSpan.Zero;
        await SetViewAsync(currentTime);
    }

    [JSInvokable]
    public Task HandleKeyDownAsync(BrowserKeyboardEvent keyboardEvent) =>
        ApplyInputCommandAsync(
            keyboardState.HandleKeyDown(
                keyboardEvent.Code,
                keyboardEvent.IsRepeat,
                MapEventTime(keyboardEvent.EventTimestampMilliseconds)));

    [JSInvokable]
    public Task HandleKeyUpAsync(BrowserKeyboardEvent keyboardEvent) =>
        ApplyInputCommandAsync(
            keyboardState.HandleKeyUp(
                keyboardEvent.Code,
                MapEventTime(keyboardEvent.EventTimestampMilliseconds)));

    [JSInvokable]
    public async Task HandleFocusLostAsync(double eventTimestampMilliseconds)
    {
        TimeSpan eventTime = MapEventTime(eventTimestampMilliseconds);
        await ApplyInputCommandAsync(keyboardState.ReleaseAll(eventTime));
        if (practiceCoordinator.IsActive)
        {
            await AbortPracticeAsync(eventTime);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await CancelVisualizationRefreshAsync();
        await AbortPracticeAsync(updateStatus: false);
        await StopScorePlaybackAsync();
        if (Metronome.IsRunning)
        {
            await StopMetronomeAsync();
        }

        if (keyboardModule is not null)
        {
            await keyboardModule.InvokeVoidAsync("dispose");
            await keyboardModule.DisposeAsync();
        }

        keyboardReference?.Dispose();
    }

    private TimeSpan GetAnchorTime() =>
        TimeSpan.FromSeconds(audioClockAnchor?.AudioTimeSeconds ?? 0);

    private TimeSpan MapEventTime(double eventTimestampMilliseconds) =>
        BrowserAudioClock.MapEventTimestamp(audioClockAnchor!, eventTimestampMilliseconds);

    private async Task AttachKeyboardAsync()
    {
        keyboardModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/keyboard.js");
        keyboardReference ??= DotNetObjectReference.Create(this);
        await keyboardModule.InvokeVoidAsync(
            "attach",
            playSurface,
            keyboardReference,
            BrowserKeyBindings.HandledCodes);
    }

    private async Task ApplyInputCommandAsync(BrowserInputCommand command)
    {
        switch (command.Kind)
        {
            case BrowserInputCommandKind.None:
                return;
            case BrowserInputCommandKind.NoteOn:
                await AudioSession.StartNoteAsync(command.NoteId!, command.Pitch!.Value, command.EventTime);
                tempoFeedbackTracker.Record(command.EventTime, Metronome.Grid, onTimeTolerance);
                audioStatus = $"Playing {command.Pitch}.";
                break;
            case BrowserInputCommandKind.NoteOff:
                await AudioSession.StopNoteAsync(command.NoteId!, command.EventTime);
                audioStatus = "Audio is ready.";
                break;
            case BrowserInputCommandKind.Clear:
                await StopScorePlaybackAsync();
                bool metronomeWasRunning = Metronome.IsRunning;
                if (metronomeWasRunning)
                {
                    await StopMetronomeAsync();
                }
                else
                {
                    tempoFeedbackTracker.Reset();
                }

                bool practiceWasActive = practiceCoordinator.State != PracticeSessionState.Idle;
                await CancelPracticeRefreshAsync();
                if (practiceWasActive)
                {
                    await practiceCoordinator.AbortAsync();
                }

                await AudioSession.ClearAsync(command.EventTime);
                testNoteIsActive = false;
                audioStatus = metronomeWasRunning
                    ? "Metronome off."
                    : practiceWasActive
                        ? "Practice aborted."
                        : "All notes cleared.";
                break;
            case BrowserInputCommandKind.ReleaseHeldNotes:
                await AudioSession.ClearAsync(command.EventTime);
                testNoteIsActive = false;
                if (!ScorePlaybackSession.IsActive)
                {
                    audioStatus = "Held notes released.";
                }

                break;
            case BrowserInputCommandKind.OctaveChanged:
                audioStatus = $"Octave {keyboardState.CurrentOctave} selected.";
                RefreshCanvasScene(command.EventTime);
                break;
            case BrowserInputCommandKind.PreviousMeasures:
                ShowPreviousMeasures();
                break;
            case BrowserInputCommandKind.NextMeasures:
                ShowNextMeasures();
                break;
            case BrowserInputCommandKind.StartScorePlayback:
                await StartScorePlaybackAsync();
                break;
            case BrowserInputCommandKind.StartPractice:
                await StartPracticeAsync();
                break;
            case BrowserInputCommandKind.ToggleView:
                await SetViewAsync(command.EventTime);
                break;
            case BrowserInputCommandKind.PlayRandomMeasure:
                await PlayRandomMeasureAsync();
                break;
            default:
                throw new InvalidOperationException($"Unsupported browser input command: {command.Kind}.");
        }

        if (command.Kind is BrowserInputCommandKind.NoteOn or
            BrowserInputCommandKind.NoteOff or
            BrowserInputCommandKind.Clear or
            BrowserInputCommandKind.ReleaseHeldNotes)
        {
            RefreshCanvasScene(command.EventTime);
            EnsureVisualizationRefresh();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshScorePlaybackAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested && loadedScore is not null)
            {
                TimeSpan currentTime = await AudioSession.GetCurrentTimeAsync(cancellationToken);

                // The grand-staff cursor now animates entirely in JS (see BuildScoreCursorState
                // and canvas.js's drawScoreCursor), so this loop no longer needs to rebuild and
                // push a fresh GrandStaffScene every tick just to move it. The piano-roll view
                // has no such client-side animation, so it still needs a per-tick rebuild while
                // score playback is what's driving it forward.
                if (showPianoRoll)
                {
                    RefreshCanvasScene(currentTime);
                    await InvokeAsync(StateHasChanged);
                }

                // Discarded: called only for its side effect of flipping IsActive once
                // currentTime reaches the schedule's completion time.
                ScorePlaybackSession.GetCursorBeats(currentTime);

                if (!ScorePlaybackSession.IsActive)
                {
                    scoreCursorState = null;
                    RefreshCanvasScene(currentTime);
                    audioStatus = "Audio is ready.";
                    EnsureVisualizationRefresh();
                    await InvokeAsync(StateHasChanged);
                    break;
                }

                await Task.Delay(
                    showPianoRoll ? CanvasRefreshInterval : PlaybackCompletionPollInterval,
                    cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task CancelPlaybackRefreshAsync()
    {
        if (playbackRefreshCancellation is null)
        {
            return;
        }

        await playbackRefreshCancellation.CancelAsync();
        if (playbackRefreshTask is not null)
        {
            await playbackRefreshTask;
        }

        playbackRefreshCancellation.Dispose();
        playbackRefreshCancellation = null;
        playbackRefreshTask = null;
    }

    private async Task RefreshPracticeAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested && loadedScore is not null)
            {
                await practiceCoordinator.UpdateAsync(cancellationToken);
                double? cursorBeats = practiceCoordinator.State is
                    PracticeSessionState.Running or PracticeSessionState.Finished
                        ? practiceCoordinator.CursorBeats
                        : null;
                RefreshCanvasScene(
                    practiceCoordinator.CurrentTime,
                    cursorBeats,
                    practiceCoordinator.GetVisibleVerdicts());
                audioStatus = practiceCoordinator.State switch
                {
                    PracticeSessionState.CountingIn => "Practice count-in.",
                    PracticeSessionState.Running => "Practice in progress.",
                    PracticeSessionState.Finished => "Practice finished.",
                    _ => audioStatus,
                };
                await InvokeAsync(StateHasChanged);

                if (practiceCoordinator.State == PracticeSessionState.Finished)
                {
                    EnsureVisualizationRefresh();
                    break;
                }

                await Task.Delay(CanvasRefreshInterval, cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task AbortPracticeAsync(TimeSpan? eventTime = null, bool updateStatus = true)
    {
        await CancelPracticeRefreshAsync();
        if (practiceCoordinator.State == PracticeSessionState.Idle)
        {
            return;
        }

        await practiceCoordinator.AbortAsync();
        if (AudioSession.IsInitialized)
        {
            TimeSpan releaseTime = eventTime ?? await AudioSession.GetCurrentTimeAsync();
            keyboardState.Clear(releaseTime);
            await AudioSession.ClearAsync(releaseTime);
        }

        if (loadedScore is not null)
        {
            RefreshCanvasScene(eventTime ?? GetAnchorTime());
        }

        if (updateStatus)
        {
            audioStatus = "Practice aborted.";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CancelPracticeRefreshAsync()
    {
        if (practiceRefreshCancellation is null)
        {
            return;
        }

        await practiceRefreshCancellation.CancelAsync();
        if (practiceRefreshTask is not null)
        {
            await practiceRefreshTask;
        }

        practiceRefreshCancellation.Dispose();
        practiceRefreshCancellation = null;
        practiceRefreshTask = null;
    }

    private async Task SetViewAsync(TimeSpan currentTime)
    {
        showPianoRoll = !showPianoRoll;
        RefreshCanvasScene(currentTime);
        UpdateScoreCursorMeasureIfPlaying();
        if (ShouldContinueVisualizationRefresh(
            showPianoRoll,
            loadedScore is not null,
            canvasScene,
            keyboardState.ActiveNoteCount))
        {
            EnsureVisualizationRefresh();
        }
        else
        {
            await CancelVisualizationRefreshAsync();
        }
    }

    private void RefreshCanvasScene(
        TimeSpan currentTime,
        double? cursorBeats = null,
        IReadOnlyDictionary<ScoreNote, Verdict>? verdicts = null)
    {
        if (showPianoRoll)
        {
            var notes = noteTimeline.Snapshot(currentTime)
                .Concat(ScorePlaybackSession.GetStartedNotes(currentTime))
                .ToArray();
            canvasScene = PianoRollSceneBuilder.Build(notes, currentTime);
            return;
        }

        canvasScene = loadedScore is null
            ? GrandStaffSceneBuilder.Build(
                noteTimeline.Snapshot(currentTime),
                currentTime,
                displayTimeSignature,
                displayTempo,
                keyboardState.CurrentOctave)
            : grandStaffSceneCache.BuildScore(loadedScore, firstVisibleMeasure, cursorBeats, verdicts);
    }

    internal static bool ShouldContinueVisualizationRefresh(
        bool showPianoRoll,
        bool hasLoadedScore,
        IPianoCanvasScene scene,
        int activeNoteCount)
    {
        if (!showPianoRoll && hasLoadedScore)
        {
            return false;
        }

        if (!showPianoRoll)
        {
            return true;
        }

        return activeNoteCount > 0 || scene switch
        {
            GrandStaffScene { Notes.Count: > 0 } => true,
            PianoRollScene { Bars.Count: > 0 } => true,
            _ => false,
        };
    }

    private void EnsureVisualizationRefresh()
    {
        if (!AudioSession.IsInitialized ||
            ScorePlaybackSession.IsActive ||
            practiceCoordinator.IsActive ||
            visualizationRefreshTask is { IsCompleted: false } ||
            !ShouldContinueVisualizationRefresh(
                showPianoRoll,
                loadedScore is not null,
                canvasScene,
                keyboardState.ActiveNoteCount))
        {
            return;
        }

        visualizationRefreshCancellation?.Dispose();
        visualizationRefreshCancellation = new CancellationTokenSource();
        visualizationRefreshTask = RefreshVisualizationAsync(visualizationRefreshCancellation.Token);
    }

    private async Task RefreshVisualizationAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                TimeSpan currentTime = await AudioSession.GetCurrentTimeAsync(cancellationToken);
                RefreshCanvasScene(currentTime);
                await InvokeAsync(StateHasChanged);
                if (!ShouldContinueVisualizationRefresh(
                    showPianoRoll,
                    loadedScore is not null,
                    canvasScene,
                    keyboardState.ActiveNoteCount))
                {
                    break;
                }

                await Task.Delay(CanvasRefreshInterval, cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task CancelVisualizationRefreshAsync()
    {
        if (visualizationRefreshCancellation is null)
        {
            return;
        }

        await visualizationRefreshCancellation.CancelAsync();
        if (visualizationRefreshTask is not null)
        {
            await visualizationRefreshTask;
        }

        visualizationRefreshCancellation.Dispose();
        visualizationRefreshCancellation = null;
        visualizationRefreshTask = null;
    }
}
